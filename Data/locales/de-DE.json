  "review": {
    "patterns": [
      "{opener} {praise}, {qualifier}.",
      "{praise} — {closer}.",
      "{opener} {qualifier}, obwohl {critique}.",
      "{praise}, und {praise2}. {closer}.",
      "{opener} {critique}, doch {praise}."
    ],
    "opener": [
      "Ein mutiger Schritt, der", "Schon im ersten Takt", "Wider Erwarten",
      "Irgendwie schafft es die Platte", "Spätestens beim zweiten Stück",
      "Mehr als ein Comeback,", "Unter der ruhigen Oberfläche",
      "Bei wiederholtem Hören", "Wo andere Bands straucheln,",
      "Zwischen Freude und Schwermut", "Mit überraschender Zurückhaltung",
      "Laut, warm und unaufgeregt"
    ],
    "praise": [
      "trägt das Album mit sicheren Hooks", "schichtet Texturen wunderbar",
      "findet Anmut im Lärm", "vertraut den leisen Momenten",
      "sitzt jeder Refrain", "swingt härter als erwartet",
      "trägt seine Einflüsse leicht", "steuert auf echte Katharsis zu",
      "glüht in analoger Wärme", "verdient jede Minute Spielzeit",
      "wird aus einer kleinen Idee eine ganze Welt", "wiederholt sich nie",
      "hält Sehnsucht und Selbstbewusstsein in Balance", "klingt gelebt statt bemüht"
    ],
    "praise2": [
      "die Rhythmusgruppe ist ein stilles Wunder", "die Melodien bleiben tagelang",
      "die Produktion atmet", "der Gesang hat echtes Gewicht",
      "die Arrangements belohnen Aufmerksamkeit", "die Abfolge ist makellos",
      "die Refrains sind unausweichlich", "die Band klingt furchtlos"
    ],
    "qualifier": [
      "auch wenn die zweite Hälfte schleppt", "ohne je zu überfordern",
      "obwohl es spät seine Nähte zeigt", "wenn man es langsam wirken lässt",
      "für alle, die ihm entgegenkommen", "ohne je die Stimme zu erheben",
      "selbst wenn die Texte stolpern", "und die Landung gelingt",
      "trotz einiger vertrauter Gesten", "und verlangt wenig zurück"
    ],
    "critique": [
      "der Mix den Gesang verschluckt", "der zweite Akt den Fokus verliert",
      "die Balladen ineinander verschwimmen", "ein paar Stücke wie Skizzen wirken",
      "es sich zu sehr auf einen Trick verlässt", "die Spielzeit die Geduld prüft",
      "die Texte selten überraschen", "die Energie in der Mitte nachlässt",
      "es Lautstärke mit Intensität verwechselt", "der Abschluss verpufft"
    ],
    "closer": [
      "ein Muss", "ein Spätzünder, kein Strohfeuer",
      "der stille Triumph des Jahres", "die Zeit absolut wert",
      "eine Platte zum Darin-Wohnen", "ihre Sternstunde",
      "fehlerhaft, aber unvergesslich", "ein Album, das man Freunden aufdrängt",
      "Beweis, dass sie es noch draufhaben", "reif für die Dauerrotation"
    ]
  },

